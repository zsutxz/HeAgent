{
  "name": "claude-code",
  "invocation": ["claude", "-p", "{prompt}", "--output-format", "stream-json", "--verbose", "--dangerously-skip-permissions"],
  "auth_env": "ANTHROPIC_API_KEY",
  "transcript": { "format": "stdout-jsonl" },
