# HeAgent 配置示例
#
# 复制为 .env 后填写真实值：
#   cp .env.example .env
#   PowerShell: Copy-Item .env.example .env
#
# 读取优先级：系统环境变量 > .env > 默认值
# 字段与 src/heagent/config.py 中的 Settings 对应

# ---------- Provider 凭据 ----------
# 至少配置一个。CLI 默认按 DeepSeek -> OpenAI -> Anthropic 的顺序组装 Provider。

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

OPENAI_API_KEY=
OPENAI_BASE_URL=

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# ---------- 多 key 池 ----------
# 同一 Provider 可配置多个 key，运行时会去重并组装为 KeyRotatingProvider。

# OPENAI_API_KEYS=sk-key1,sk-key2
# ANTHROPIC_API_KEYS=key1,key2

# ---------- Anthropic 提示缓存 ----------
# 对不支持 cache_control 的代理请显式关闭。

ANTHROPIC_PROMPT_CACHING=true

# ---------- 模型与 Agent 运行参数 ----------

# DEFAULT_MODEL=gpt-4o
# MAX_ITERATIONS=50
# COMPRESSION_THRESHOLD=0.8
# MAX_CONTEXT_TOKENS=128000
# SHELL_TIMEOUT=120

# ---------- 重试参数 ----------

# RETRY_MAX_ATTEMPTS=3
# RETRY_BASE_DELAY=1.0
# RETRY_MAX_DELAY=30.0

# ---------- 技能 / 记忆 / 上下文 ----------

# SKILL_MATCH_THRESHOLD=0.3
# SKILL_MAX_AUTO_INVOKE=3
# CONTEXT_FILES_ENABLED=true
# MEMORY_NUDGE_ENABLED=true
# SKILL_CURATOR_STALE_DAYS=30

# ---------- Cron ----------

# CRON_ENABLED=true
# CRON_TICK_SECONDS=60

# ---------- MCP ----------

# MCP_ENABLED=true
# MCP_CONFIG_PATH=.mcp.json
