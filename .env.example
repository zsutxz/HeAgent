# ============================================================
# HeAgent 配置示例 — 复制为 .env 并填入真实值
#
#   cp .env.example .env
#   # Windows PowerShell: Copy-Item .env.example .env
#
# 加载优先级：系统环境变量 > .env > 字段默认值
# .env 已被 .gitignore 忽略，切勿提交真实密钥
# 字段名与 src/heagent/config.py 的 Settings 一一对应
# ============================================================

# ---------- LLM Provider 密钥 ----------
# 至少配置一个。CLI 按 DeepSeek > OpenAI > Anthropic 顺序自动检测可用 provider。

# DeepSeek（OpenAI 兼容，优先检测）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI（或任意 OpenAI 兼容服务，如智谱 AI —— 配合 OPENAI_BASE_URL）
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# ---------- 多密钥池（逗号分隔） ----------
# Settings 支持解析，但 ProviderChain 当前仅在 provider 间切换，不做密钥轮换。
# OPENAI_API_KEYS=sk-key1,sk-key2,sk-key3
# ANTHROPIC_API_KEYS=sk-ant-key1,sk-ant-key2

# ---------- Anthropic 提示词缓存 ----------
# 对 system prompt 注入 cache_control 断点，降低重复输入成本。
# 使用不支持 cache_control 的代理时设为 false。
ANTHROPIC_PROMPT_CACHING=true

# ---------- 框架运行参数（取消注释以覆盖默认值） ----------
# DEFAULT_MODEL=gpt-4o
# MAX_ITERATIONS=50
# COMPRESSION_THRESHOLD=0.8
# MAX_CONTEXT_TOKENS=128000
# SHELL_TIMEOUT=120

# ---------- 重试策略 ----------
# RETRY_MAX_ATTEMPTS=3
# RETRY_BASE_DELAY=1.0
# RETRY_MAX_DELAY=30.0

# ---------- 技能系统 ----------
# SKILL_MATCH_THRESHOLD=0.3
# SKILL_MAX_AUTO_INVOKE=3

# ---------- 其他 ----------
# CONTEXT_FILES_ENABLED=true
# MEMORY_NUDGE_ENABLED=true
# SKILL_CURATOR_STALE_DAYS=30
# CRON_ENABLED=true
# CRON_TICK_SECONDS=60
