# HeAgent 运行配置示例
#
# 用法：
#   cp .env.production.example .env.production
#   然后把真实密钥填进去
#
# 说明：
# - 这个文件只保留当前核心代码会读取的配置项
# - 如果你有自己的容器编排或服务包装层，额外环境变量请放在部署系统里维护

# ---------- Provider ----------

DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ---------- 可选 key 池 ----------

# OPENAI_API_KEYS=sk-a,sk-b
# ANTHROPIC_API_KEYS=key-a,key-b

# ---------- 运行参数 ----------

DEFAULT_MODEL=deepseek-chat
MAX_ITERATIONS=20
COMPRESSION_THRESHOLD=0.8
MAX_CONTEXT_TOKENS=128000
SHELL_TIMEOUT=120

RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY=1.0
RETRY_MAX_DELAY=30.0

SKILL_MATCH_THRESHOLD=0.3
SKILL_MAX_AUTO_INVOKE=3
CONTEXT_FILES_ENABLED=true
MEMORY_NUDGE_ENABLED=true
SKILL_CURATOR_STALE_DAYS=30

CRON_ENABLED=true
CRON_TICK_SECONDS=60

MCP_ENABLED=true
MCP_CONFIG_PATH=.mcp.json
